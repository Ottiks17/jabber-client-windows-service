                                 padx=20, pady=8, borderwidth=0,
                                 cursor='hand2')
        refresh_btn.pack(pady=(0, 15))
        
    def update_char_counter(self, event=None):
        text = self.send_text.get("1.0", tk.END).strip()
        count = len(text)
        self.char_counter.config(text=f"{count} / 256")
        
        if count > 256:
            self.char_counter.config(fg='#EF4444')
        else:
            self.char_counter.config(fg=self.colors['text_secondary'])

    def insert_template(self, text):
        self.send_text.delete("1.0", tk.END)
        self.send_text.insert("1.0", text)
        self.update_char_counter()

    def send_message_from_gui(self):
        recipient = self.send_recipient.get().strip()
        subject = self.send_subject.get().strip()
        text = self.send_text.get("1.0", tk.END).strip()
        
        if not recipient or not text:
            messagebox.showwarning("Ошибка", "Заполните получателя и сообщение")
            return
        
        if len(text) > 256:
            messagebox.showwarning("Ошибка", "Сообщение превышает 256 символов")
            return
        
        full_text = f"[{subject}]\n{text}" if subject else text
        
        self.send_btn.config(state='disabled', text="⏳ ОТПРАВКА...")
        self.send_status.config(text="Отправка...", fg=self.colors['warning'])
        
        def send():
            try:
                response = requests.post(
                    'http://localhost:5000/api/send',
                    json={
                        'recipient': recipient,
                        'message': full_text,
                        'sender': 'gui_user'
                    },
                    timeout=10
                )
                
                if response.status_code == 200:
                    self.root.after(0, self.on_send_success)
                else:
                    error = response.json().get('error', 'Unknown error')
                    self.root.after(0, lambda: self.on_send_error(error))
                    
            except requests.exceptions.ConnectionError:
                self.root.after(0, lambda: self.on_send_error("API сервер не запущен"))
            except Exception as e:
                self.root.after(0, lambda: self.on_send_error(str(e)))
        
        threading.Thread(target=send, daemon=True).start()

    def on_send_success(self):
        self.send_btn.config(state='normal', text="📨 ОТПРАВИТЬ СООБЩЕНИЕ")
        self.send_status.config(text="✅ Сообщение отправлено!", fg=self.colors['success'])
        self.send_text.delete("1.0", tk.END)
        self.send_subject.delete(0, tk.END)
        self.update_char_counter()
        self.root.after(3000, lambda: self.send_status.config(text=""))

    def on_send_error(self, error):
        self.send_btn.config(state='normal', text="📨 ОТПРАВИТЬ СООБЩЕНИЕ")
        self.send_status.config(text=f"❌ {error}", fg=self.colors['error'])
        self.root.after(5000, lambda: self.send_status.config(text=""))
        
    def refresh_logs(self):
        if hasattr(self, 'logger'):
            self.log_text.delete(1.0, tk.END)
            logs = self.logger.get_logs()[-50:]
            for log in reversed(logs):
                status = "✓" if log.sent_time else "⏳"
                self.log_text.insert(tk.END, 
                    f"[{log.created_at.strftime('%H:%M:%S')}] {status} {log.message_type}: {log.sender} → {log.recipient}\n"
                    f"   📝 {log.text[:100]}\n"
                    f"   {'─'*70}\n\n"
                )
                
    def start_service(self):
        try:
            sources = []
            if self.oracle_enabled.get():
                sources.append(OracleSource())
            if self.rest_enabled.get():
                sources.append(RestSource(
                    api_url=self.rest_url.get(),
                    api_key=self.rest_key.get()
                ))
                
            sender = XmppSender(
                server=self.xmpp_server.get(),
                username=self.xmpp_username.get(),
                password=self.xmpp_password.get()
            )
            
            self.logger = FileLogger()
            self.core = MessagingCore(sources, sender, self.logger)
            
            self.core_thread = threading.Thread(target=self.core.start)
            self.core_thread.daemon = True
            self.core_thread.start()
            
            self.status_label.config(text="Сервис запущен")
            self.start_btn.config(state='disabled')
            self.stop_btn.config(state='normal')
            self.status_canvas.itemconfig(self.status_dot, fill=self.colors['success'])
            
            messagebox.showinfo("Успех", "🚀 Сервис успешно запущен")
            
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось запустить сервис: {e}")
            
    def stop_service(self):
        if self.core:
            self.core.stop()
            self.core = None
            
        self.status_label.config(text="Сервис остановлен")
        self.start_btn.config(state='normal')
        self.stop_btn.config(state='disabled')
        self.status_canvas.itemconfig(self.status_dot, fill='#64748B')
        
        messagebox.showinfo("Успех", "⏹ Сервис остановлен")
        
    def run(self):
        self.root.mainloop()