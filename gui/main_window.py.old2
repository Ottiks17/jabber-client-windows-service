                 background=[('active', 'rgba(99, 102, 241, 0.4)')])
        
        # Вкладки
        style.configure('TNotebook', background=self.colors['bg'], borderwidth=0)
        style.configure('TNotebook.Tab',
                       background=self.colors['bg'],
