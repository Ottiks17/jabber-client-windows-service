                       foreground=self.colors['text'],
                       font=('Inter', 28, 'bold'))
        
        style.configure('H1.TLabel',
                       background=self.colors['bg'],
                       foreground=self.colors['text'],
                       font=('Inter', 20, 'bold'))
        
        style.configure('H2.TLabel',
                       background=self.colors['bg'],
                       foreground=self.colors['text_secondary'],
                       font=('Inter', 14))
        
        style.configure('Status.TLabel',
