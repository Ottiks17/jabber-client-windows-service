class MainWindow:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("🤖 JABBER ROBOT 2026")
        self.root.geometry("1280x800")
        
        # Убираем стандартные рамки
        self.root.overrideredirect(False)
        
        # Устанавливаем современную тему
        self.setup_theme()
        
        # Устанавливаем иконку
        try:
            self.root.iconbitmap('icon.ico')
        except:
            pass
        
        self.core = None
        self.config = self.load_config()
        
        self.setup_ui()
        
        # Настройка скролла колесиком
        self.setup_scroll_binding()
        
