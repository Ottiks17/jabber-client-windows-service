        canvas.configure(yscrollcommand=scrollbar.set)
        
        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")
        
        # XMPP карточка
        xmpp_card = ttk.Frame(scrollable_frame, style='Card.TFrame')
        xmpp_card.pack(fill='x', padx=20, pady=10)
        
        xmpp_header = ttk.Label(xmpp_card, text="📡 XMPP Настройки", 
                                 style='Header.TLabel')
        xmpp_header.pack(anchor='w', padx=15, pady=(15, 10))
        
        # XMPP поля
        fields_frame = ttk.Frame(xmpp_card, style='Card.TFrame')
