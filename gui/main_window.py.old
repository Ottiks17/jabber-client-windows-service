        # Пароль
        ttk.Label(fields_frame, text="Пароль:", style='Status.TLabel').grid(row=2, column=0, sticky='w', pady=5)
        self.xmpp_password = ttk.Entry(fields_frame, width=40, show="*", font=('Segoe UI', 10))
        self.xmpp_password.insert(0, self.config['xmpp'].get('password', ''))
        self.xmpp_password.grid(row=2, column=1, padx=10, pady=5)
        
        # Источники карточка
        sources_card = ttk.Frame(scrollable_frame, style='Card.TFrame')
        sources_card.pack(fill='x', padx=20, pady=10)
        
        sources_header = ttk.Label(sources_card, text="📂 Источники сообщений", 
