        sources_header.pack(anchor='w', padx=15, pady=(15, 10))
        
        sources_frame = ttk.Frame(sources_card, style='Card.TFrame')
        sources_frame.pack(fill='x', padx=15, pady=10)
        
        self.oracle_enabled = tk.BooleanVar(value=self.config['oracle'].get('enabled', True))
        oracle_check = ttk.Checkbutton(sources_frame, text="Oracle БД", 
