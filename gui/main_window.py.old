        scrollbar = ttk.Scrollbar(parent, orient="vertical", command=canvas.yview)
        scrollable_frame = ttk.Frame(canvas, style='Dark.TFrame')
        
        scrollable_frame.bind(
            "<Configure>",
            lambda e: canvas.configure(scrollregion=canvas.bbox("all"))
        )
        
        canvas.create_window((0, 0), window=scrollable_frame, anchor="nw")
        canvas.configure(yscrollcommand=scrollbar.set)
        
        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")
        
        # Карточка отправки
        send_card = ttk.Frame(scrollable_frame, style='Card.TFrame')
        send_card.pack(fill='both', expand=True, padx=20, pady=10)
        
        header = ttk.Label(send_card, text="✉️ Отправить сообщение", 
                           style='Header.TLabel')
        header.pack(anchor='w', padx=15, pady=(15, 10))
        
        # Поля
        fields_frame = ttk.Frame(send_card, style='Card.TFrame')
        fields_frame.pack(fill='x', padx=15, pady=10)
        
        # Получатель
        ttk.Label(fields_frame, text="Получатель (JID):", style='Status.TLabel').pack(anchor='w', pady=(0, 2))
        self.send_recipient = ttk.Entry(fields_frame, width=50, font=('Segoe UI', 10))
        self.send_recipient.pack(fill='x', pady=(0, 10))
        
        # Тема
        ttk.Label(fields_frame, text="Тема (опционально):", style='Status.TLabel').pack(anchor='w', pady=(0, 2))
        self.send_subject = ttk.Entry(fields_frame, width=50, font=('Segoe UI', 10))
        self.send_subject.pack(fill='x', pady=(0, 10))
        
        # Сообщение
        ttk.Label(fields_frame, text="Сообщение:", style='Status.TLabel').pack(anchor='w', pady=(0, 2))
        self.send_text = tk.Text(fields_frame, height=6, width=50, 
                                  wrap=tk.WORD, font=('Segoe UI', 10),
                                  bg='#0f3460', fg='#eeeeee', insertbackground='white',
                                  relief='flat', borderwidth=0)
        self.send_text.pack(fill='x', pady=(0, 5))
        
        # Счетчик символов
        self.char_counter = ttk.Label(fields_frame, text="0 / 256 символов", 
                                       style='Status.TLabel')
        self.char_counter.pack(anchor='e', pady=(0, 10))
        self.send_text.bind('<KeyRelease>', self.update_char_counter)
        
        # Кнопка отправки
        self.send_button = ttk.Button(fields_frame, text="📨 Отправить", 
                                       command=self.send_message_from_gui,
                                       style='Accent.TButton')
        self.send_button.pack(pady=10)
        
        # Статус отправки
        self.send_status = ttk.Label(fields_frame, text="", style='Status.TLabel')
        self.send_status.pack(pady=5)
        
        # Шаблоны
        templates_label = ttk.Label(send_card, text="📋 Быстрые шаблоны", 
                                     style='Header.TLabel')
        templates_label.pack(anchor='w', padx=15, pady=(10, 5))
        
        templates_frame = ttk.Frame(send_card, style='Card.TFrame')
        templates_frame.pack(fill='x', padx=15, pady=10)
        
        templates = [
            ("Привет!", "Привет! Как дела?"),
            ("Совещание", "Напоминаю о совещании в 15:00"),
            ("Отчет", "Отчет готов. Можно посмотреть в папке."),
            ("Тест", "Тестовое сообщение из Jabber Robot")
        ]
        
        for i, (name, text) in enumerate(templates):
            btn = ttk.Button(templates_frame, text=name, 
                             command=lambda t=text: self.insert_template(t),
                             style='Secondary.TButton')
            btn.grid(row=i//2, column=i%2, padx=5, pady=5, sticky='ew')
        
        templates_frame.columnconfigure(0, weight=1)
        templates_frame.columnconfigure(1, weight=1)
        
        # Информация
        info_frame = ttk.Frame(send_card, style='Card.TFrame')
        info_frame.pack(fill='x', padx=15, pady=10)
        
        info_text = "💡 Совет: Убедитесь, что API сервер запущен (python api_server.py)\n   Максимальная длина сообщения: 256 символов"
        info_label = ttk.Label(info_frame, text=info_text, 
                                style='Status.TLabel', justify='left')
        info_label.pack(pady=10)
        
    def setup_logs_tab(self, parent):
        # Карточка логов
        logs_card = ttk.Frame(parent, style='Card.TFrame')
        logs_card.pack(fill='both', expand=True, padx=20, pady=10)
        
        header = ttk.Label(logs_card, text="📋 История сообщений", 
                           style='Header.TLabel')
        header.pack(anchor='w', padx=15, pady=(15, 10))
        
        self.log_text = scrolledtext.ScrolledText(logs_card, wrap=tk.WORD, 
                                                    height=20, font=('Consolas', 9),
                                                    bg='#0f3460', fg='#eeeeee',
                                                    insertbackground='white',
                                                    relief='flat', borderwidth=0)
        self.log_text.pack(fill='both', expand=True, padx=15, pady=10)
        
        btn_frame = ttk.Frame(logs_card, style='Card.TFrame')
        btn_frame.pack(fill='x', padx=15, pady=(0, 15))
        
        refresh_btn = ttk.Button(btn_frame, text="🔄 Обновить", 
                                  command=self.refresh_logs,
                                  style='Secondary.TButton')
        refresh_btn.pack(side='right')
        
    def update_char_counter(self, event=None):
        text = self.send_text.get("1.0", tk.END).strip()
        count = len(text)
        self.char_counter.config(text=f"{count} / 256 символов")
        
        if count > 256:
            self.char_counter.config(foreground='#e94560')
        else:
            self.char_counter.config(foreground='#a0a0a0')

    def insert_template(self, text):
        self.send_text.delete("1.0", tk.END)
        self.send_text.insert("1.0", text)
        self.update_char_counter()

    def send_message_from_gui(self):
        recipient = self.send_recipient.get().strip()
        subject = self.send_subject.get().strip()
        text = self.send_text.get("1.0", tk.END).strip()
        
        if not recipient:
            messagebox.showwarning("Ошибка", "Введите получателя")
            return
        
        if not text:
            messagebox.showwarning("Ошибка", "Введите текст сообщения")
            return
        
        if len(text) > 256:
            messagebox.showwarning("Ошибка", f"Сообщение превышает 256 символов")
            return
        
        full_text = f"[{subject}]\n{text}" if subject else text
        
        self.send_button.config(state='disabled', text="⏳ Отправка...")
        self.send_status.config(text="Отправка...", foreground='#ffd93d')
        
        def send():
            try:
                response = requests.post(
                    'http://localhost:5000/api/send',
                    json={
                        'recipient': recipient,
                        'message': full_text,
                        'sender': 'gui_user'
                    },
                    timeout=10
                )
                
                if response.status_code == 200:
                    self.root.after(0, self.on_send_success)
                else:
                    error = response.json().get('error', 'Unknown error')
                    self.root.after(0, lambda: self.on_send_error(error))
                    
            except requests.exceptions.ConnectionError:
                self.root.after(0, lambda: self.on_send_error("API сервер не запущен!"))
            except Exception as e:
                self.root.after(0, lambda: self.on_send_error(str(e)))
        
        threading.Thread(target=send, daemon=True).start()

    def on_send_success(self):
        self.send_button.config(state='normal', text="📨 Отправить")
        self.send_status.config(text="✅ Сообщение отправлено!", foreground='#4caf50')
        self.send_text.delete("1.0", tk.END)
        self.send_subject.delete(0, tk.END)
        self.update_char_counter()
        self.root.after(3000, lambda: self.send_status.config(text=""))

    def on_send_error(self, error):
        self.send_button.config(state='normal', text="📨 Отправить")
        self.send_status.config(text=f"❌ {error}", foreground='#e94560')
        self.root.after(5000, lambda: self.send_status.config(text=""))
        
    def refresh_logs(self):
        if hasattr(self, 'logger'):
            self.log_text.delete(1.0, tk.END)
            for log in self.logger.get_logs()[-50:]:  # Последние 50
                self.log_text.insert(tk.END, 
                    f"[{log.created_at}] {log.message_type}: {log.sender} → {log.recipient}\n"
                    f"    📝 {log.text}\n"
                    f"    ✓ Отправлено: {log.sent_time or '—'}\n"
                    f"{'─'*60}\n"
                )
                
    def start_service(self):
        try:
            sources = []
            
            if self.oracle_enabled.get():
                sources.append(OracleSource())
                
            if self.rest_enabled.get():
                sources.append(RestSource(
                    api_url=self.rest_url.get(),
                    api_key=self.rest_key.get()
                ))
                
            sender = XmppSender(
                server=self.xmpp_server.get(),
                username=self.xmpp_username.get(),
                password=self.xmpp_password.get()
            )
            
            self.logger = FileLogger()
            self.core = MessagingCore(sources, sender, self.logger)
            
            self.core_thread = threading.Thread(target=self.core.start)
            self.core_thread.daemon = True
            self.core_thread.start()
            
            self.status_label.config(text="Работает")
            self.start_button.config(state='disabled')
            self.stop_button.config(state='normal')
            
            # Обновляем индикатор
            self.status_indicator.itemconfig(self.status_circle, fill='#4caf50')
            
            messagebox.showinfo("Успех", "🚀 Сервис запущен")
            
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось запустить сервис: {e}")
            
    def stop_service(self):
        if self.core:
            self.core.stop()
            self.core = None
            
        self.status_label.config(text="Остановлен")
        self.start_button.config(state='normal')
        self.stop_button.config(state='disabled')
        
        # Обновляем индикатор
        self.status_indicator.itemconfig(self.status_circle, fill='#888')
        
        messagebox.showinfo("Успех", "⏹ Сервис остановлен")
        
    def run(self):
        self.root.mainloop()